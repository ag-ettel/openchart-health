# Production environment for openchart.health (Cloudflare Pages).
# Copy to .env.production or set in Cloudflare Pages > Settings > Environment.

# Canonical site URL — drives canonical links, sitemap.xml, JSON-LD, OG tags.
# Defaults to https://openchart.health if unset (DEFAULT_SITE_URL in lib/constants.ts).
NEXT_PUBLIC_SITE_URL=https://openchart.health

# CDN base for runtime provider JSON fetches on /compare and /filter-explore.
# In production this is the same origin (static export under public/data/).
# In local dev, set to /data so the Next.js dev server serves from public/data/.
NEXT_PUBLIC_CDN_BASE=/data

# Plausible analytics. Absence is a no-op (script omitted, no errors).
# Set the registered domain (without protocol) once analytics is configured.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=openchart.health

# Sentry frontend error monitoring. Absence is a no-op (init skipped, no
# warnings, no overhead). Errors from the runtime-fetching pages /compare
# and /filter-explore are wrapped in SentryErrorBoundary.
# Provision in Sentry, copy DSN, set in Cloudflare Pages env.
# NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload. All three are required to upload maps; without
# them the build still succeeds (maps emitted but not uploaded). Generate
# the auth token at https://openchart-health.sentry.io/settings/account/api/auth-tokens/
# with project:write scope. Mark SENTRY_AUTH_TOKEN as Encrypted in Cloudflare.
# SENTRY_ORG=openchart-health
# SENTRY_PROJECT=openchart-health
# SENTRY_AUTH_TOKEN=
